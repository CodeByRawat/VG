# Required. Used server-side only, never exposed to the client.
OPENAI_API_KEY=sk-...

# Required only if you want the "Nano Banana" (Gemini 2.5 Flash Image)
# option in the image-provider dropdown. Get one from Google AI Studio.
# Note: image generation is NOT included in the Gemini API free tier —
# you need billing enabled on the associated Google Cloud project, or
# every generation call will fail with a 429 quota error.
GEMINI_API_KEY=

# Optional. If set, the app shows a password gate before it can be used,
# so a leaked Vercel URL can't burn your OpenAI credits. Leave unset to
# skip the gate entirely.
ACCESS_PASSWORD=
