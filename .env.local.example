# Which image generation backend to use: "pollinations" (free, no API
# key needed) or "openai" (uses gpt-image-1, requires OPENAI_API_KEY
# below). Only affects image generation. Defaults to "pollinations" if
# unset.
IMAGE_PROVIDER=pollinations

# Required for the "Auto-write visual prompts" step (gpt-4o-mini),
# regardless of IMAGE_PROVIDER above. Also required for image
# generation if IMAGE_PROVIDER=openai. Used server-side only, never
# exposed to the client.
OPENAI_API_KEY=sk-...

# Optional. If set, the app shows a password gate before it can be used,
# so a leaked Vercel URL can't burn your OpenAI credits. Leave unset to
# skip the gate entirely.
ACCESS_PASSWORD=
